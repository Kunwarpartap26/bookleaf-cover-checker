# ─────────────────────────────────────────────────────────
# BookLeaf Cover Checker — Environment Configuration
# Copy this file to .env and fill in your credentials.
# NEVER commit .env or credentials.json to version control.
# ─────────────────────────────────────────────────────────

# Google Drive
# The ID of the Drive folder where authors upload their covers.
# Find it in the URL: drive.google.com/drive/folders/<FOLDER_ID>
GOOGLE_DRIVE_FOLDER_ID=your_folder_id_here

# Path to your Google service account key JSON file.
GOOGLE_CREDENTIALS_PATH=credentials.json

# Airtable
# Create a Personal Access Token at: airtable.com/create/tokens
AIRTABLE_TOKEN=your_airtable_token_here

# Your Airtable base ID — visible in the URL when viewing the base:
# airtable.com/<BASE_ID>/...
AIRTABLE_BASE_ID=your_base_id_here

# The exact name of your Airtable table (must match what you created)
AIRTABLE_TABLE_NAME=Cover Tracker

# Gmail — use an App Password, not your real Gmail password.
# Generate one at: myaccount.google.com/apppasswords
# Requires 2-Factor Authentication to be enabled on your account.
GMAIL_ADDRESS=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Flask
FLASK_PORT=5000
FLASK_DEBUG=False

# Used as a base URL when building Annotation URL links in Airtable.
# Change this if you deploy the app somewhere other than localhost.
FLASK_BASE_URL=http://localhost:5000

# Fallback email address for books whose ISBN isn't in isbn_db.py
DEFAULT_AUTHOR_EMAIL=test@example.com
